    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
