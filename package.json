{
  "name": "@tuned-tensor/local",
  "version": "0.1.9",
  "description": "TT Local: tuning tensors locally on hardware you control.",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/tunedtensor/tuned-tensor-local"
  },
  "type": "module",
  "bin": {
    "tt-local": "dist/index.js",
    "tuned-tensor-local": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "training",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
