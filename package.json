{
  "name": "tuned-tensor-local",
  "version": "0.1.0",
  "description": "Local, cloud-independent fine-tuning runner for Tuned Tensor behavior specs.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "bin": {
    "tt-local": "./dist/index.js",
    "tuned-tensor-local": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "training",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
